#!/usr/bin/env bash

set -o errexit -o nounset -o pipefail

SCRIPT_NAME=$(basename "$(readlink -f "${BASH_SOURCE[0]}")")

toplevel() {
    darcs show repo | grep 'Root:' | sed 's/.*Root: //'
}

rebase-dir() {
    read -r _top < <(toplevel)
    printf '%s/_darcs/rebase-i\n' "$_top"
}

# Returns "hash\tname" pairs, oldest first, with the shortest prefix that
# uniquely distinguishes all N hashes among themselves (minimum 7, like git).
patch-info-oldest-first() {
    local n=$1

    local full_hashes=() names=()
    local current_hash=''
    while IFS= read -r line; do
        if [[ $line =~ \<patch[[:space:]] ]]; then
            current_hash="${line#*hash=\'}"
            current_hash="${current_hash%%\'*}"
        elif [[ $line =~ \<name\> ]]; then
            local name="${line#*<name>}"
            name="${name%%</name>*}"
            name="${name//&amp;/&}"
            name="${name//&lt;/<}"
            name="${name//&gt;/>}"
            name="${name//&quot;/\"}"
            full_hashes+=("$current_hash")
            names+=("$name")
        fi
    done < <(darcs log --xml-output --last="$n")

    # Reverse to oldest-first.
    local lo=0 hi=$(( ${#full_hashes[@]} - 1 ))
    while (( lo < hi )); do
        local tmp="${full_hashes[$lo]}"; full_hashes[$lo]="${full_hashes[$hi]}"; full_hashes[$hi]="$tmp"
        tmp="${names[$lo]}"; names[$lo]="${names[$hi]}"; names[$hi]="$tmp"
        (( lo++, hi-- ))
    done

    # Find minimum prefix length where all hashes are distinct (min 7).
    local len=7
    while (( len < ${#full_hashes[0]} )); do
        local unique=true
        local i j
        for (( i=0; i<${#full_hashes[@]}-1; i++ )); do
            for (( j=i+1; j<${#full_hashes[@]}; j++ )); do
                if [[ "${full_hashes[$i]:0:$len}" == "${full_hashes[$j]:0:$len}" ]]; then
                    unique=false
                    break 2
                fi
            done
        done
        $unique && break
        (( len++ ))
    done

    local i
    for (( i=0; i<${#full_hashes[@]}; i++ )); do
        printf '%s\t%s\n' "${full_hashes[$i]:0:$len}" "${names[$i]}"
    done
}

# Escape ERE metacharacters and anchor for use as a darcs --patches pattern.
escape-patch-name() {
    printf '^%s$' "$(printf '%s' "$1" | sed 's/[]\[\\^$.*+?|(){}]/\\&/g')"
}

# Run darcs, feeding 'y' to any author-mismatch prompts and suppressing their text.
darcs-yes() {
    { yes y 2>/dev/null | darcs "$@" 2>&1 || [[ ${PIPESTATUS[1]} -eq 0 ]]; } \
        | sed "s/You're not [^!]*! [A-Za-z]* anyway?  *\[yn[a]*\] *//g"
}

# Core execution engine (shared env — not a subshell)
execute-todo() {
    local rebase_dir=$1
    local todo="$rebase_dir/todo"

    local todo_lines=()
    while IFS= read -r line; do
        todo_lines+=("$line")
    done < "$todo"

    local last_pick_name=""
    local idx

    # Track which hashes were explicitly processed (for cleanup).
    local processed_hashes=()

    for (( idx=0; idx<${#todo_lines[@]}; idx++ )); do
        local line="${todo_lines[$idx]}"
        local action rest hash name
        action=${line%% *}
        rest=${line#* }

        case $action in
            exec|break)
                hash=''
                name=$rest
                ;;
            *)
                hash=${rest%% *}
                name=${rest#* }
                name="${name#\# }"
                processed_hashes+=("$hash")
                ;;
        esac

        # Checkpoint: rewrite todo with current + remaining BEFORE executing.
        # If a darcs command fails (errexit), the file reflects the correct resume point.
        {
            local j
            for (( j=idx; j<${#todo_lines[@]}; j++ )); do
                printf '%s\n' "${todo_lines[$j]}"
            done
        } > "$todo"

        local escaped_name
        escaped_name=$(escape-patch-name "$name")

        # For patch actions: unsuspend the current patch (may flood in same-named
        # duplicates), then re-suspend any that appear later in the todo.
        # The original todo hashes are stale after a suspend/unsuspend round-trip
        # (darcs reassigns hashes), so we look up current hashes from darcs log.
        if [[ -n $hash ]]; then
            darcs-yes rebase unsuspend --quiet --patches "$escaped_name"

            local count_future=0 j
            for (( j=idx+1; j<${#todo_lines[@]}; j++ )); do
                local fline="${todo_lines[$j]}"
                local faction="${fline%% *}"
                [[ $faction == exec || $faction == break ]] && continue
                local frest="${fline#* }"
                local fname="${frest#* }"
                [[ "$fname" == "$name" ]] && count_future=$(( count_future + 1 ))
            done

            if (( count_future > 0 )); then
                # Gather the count_future most-recently-applied same-named patches
                # from darcs log (newest-first) and re-suspend them.
                local future_hashes=() curr_hash="" curr_name
                while IFS= read -r xml_line; do
                    if [[ $xml_line =~ \<patch[[:space:]] ]]; then
                        curr_hash="${xml_line#*hash=\'}"
                        curr_hash="${curr_hash%%\'*}"
                    elif [[ $xml_line =~ \<name\> ]]; then
                        curr_name="${xml_line#*<name>}"
                        curr_name="${curr_name%%</name>*}"
                        curr_name="${curr_name//&amp;/&}"
                        curr_name="${curr_name//&lt;/<}"
                        curr_name="${curr_name//&gt;/>}"
                        curr_name="${curr_name//&quot;/\"}"
                        if [[ "$curr_name" == "$name" ]]; then
                            future_hashes+=("$curr_hash")
                            if (( ${#future_hashes[@]} >= count_future )); then break; fi
                        fi
                    fi
                done < <(darcs log --xml-output --patches "$escaped_name")

                local k
                for (( k=0; k<${#future_hashes[@]}; k++ )); do
                    darcs-yes rebase suspend --all --quiet --hash "${future_hashes[$k]}"
                done
            fi
        fi

        case $action in
            pick)
                last_pick_name=$name
                ;;

            drop)
                darcs-yes obliterate --all --quiet --dont-prompt-for-dependencies --patches "$escaped_name" --last=1
                ;;

            reword)
                darcs amend --all --edit-long-comment
                last_pick_name=$name
                ;;

            squash)
                [[ -n $last_pick_name ]] || {
                    printf '%s: squash has no previous pick to merge into\n' "$SCRIPT_NAME" >&2
                    exit 1
                }
                darcs-yes unrecord --all --quiet --last=1
                local squash_msg_file squash_editor_script
                squash_msg_file=$(mktemp)
                squash_editor_script=$(mktemp)
                printf '%s\n' "$name" > "$squash_msg_file"
                cat > "$squash_editor_script" << 'EOF'
#!/usr/bin/env bash
tmpfile=$(mktemp)
awk -v msg_file="$SQUASH_MSG_FILE" '
    !inserted && /^#/ {
        while ((getline line < msg_file) > 0) print line
        print ""
        inserted = 1
    }
    { print }
' "$1" > "$tmpfile" && mv "$tmpfile" "$1"
exec "${DARCS_REAL_EDITOR:-${VISUAL:-${EDITOR:-vi}}}" "$1"
EOF
                chmod +x "$squash_editor_script"
                SQUASH_MSG_FILE="$squash_msg_file" \
                    DARCS_REAL_EDITOR="${DARCS_EDITOR:-}" \
                    DARCS_EDITOR="$squash_editor_script" \
                    darcs amend --all --edit-long-comment
                rm -f "$squash_msg_file" "$squash_editor_script"
                ;;

            fixup)
                [[ -n $last_pick_name ]] || {
                    printf '%s: fixup has no previous pick to merge into\n' "$SCRIPT_NAME" >&2
                    exit 1
                }
                darcs-yes unrecord --all --quiet --last=1
                darcs-yes amend --all
                ;;

            edit)
                local remaining=()
                local j
                for (( j=idx+1; j<${#todo_lines[@]}; j++ )); do
                    remaining+=("${todo_lines[$j]}")
                done

                if [[ ${#remaining[@]} -gt 0 ]]; then
                    printf '%s\n' "${remaining[@]}" > "$todo"
                else
                    rm -f "$todo"
                fi

                printf '\nStopped at: %s\n' "$name"
                printf 'Make your changes, then run:\n'
                printf '  %s --continue\n' "$SCRIPT_NAME"
                printf 'To cancel the rebase:\n'
                printf '  %s --abort\n' "$SCRIPT_NAME"
                exit 0
                ;;

            exec)
                bash -c "$name" || {
                    printf '%s: exec command failed: %s\n' "$SCRIPT_NAME" "$name" >&2
                    printf 'Fix the issue and run:\n'
                    printf '  %s --continue\n' "$SCRIPT_NAME"
                    exit 1
                }
                ;;

            break)
                local rest_lines=()
                local j
                for (( j=idx+1; j<${#todo_lines[@]}; j++ )); do
                    rest_lines+=("${todo_lines[$j]}")
                done

                if [[ ${#rest_lines[@]} -gt 0 ]]; then
                    printf '%s\n' "${rest_lines[@]}" > "$todo"
                else
                    rm -f "$todo"
                fi

                printf '\nStopped at break point.\n'
                printf 'Run:\n'
                printf '  %s --continue\n' "$SCRIPT_NAME"
                exit 0
                ;;
        esac
    done

    # Obliterate patches implicitly dropped by deleting their line in the editor.
    # Read original hashes+names; any hash not processed by the todo loop is still suspended.
    local orig_hashes=()
    local orig_names=()
    while IFS=$'\t' read -r ohash oname; do
        orig_hashes+=("$ohash")
        orig_names+=("$oname")
    done < "$rebase_dir/original-order"

    # Group dropped patches by name so that when multiple same-named patches are
    # dropped, we unsuspend them all at once (one call per unique name) and then
    # obliterate them one at a time with --last=1.
    local handled_cleanup_names=()
    local i
    for (( i=0; i<${#orig_hashes[@]}; i++ )); do
        local found=false ph
        for ph in "${processed_hashes[@]}"; do
            [[ "$ph" == "${orig_hashes[$i]}" ]] && { found=true; break; }
        done
        $found && continue

        local oname="${orig_names[$i]}"

        local already_handled=false hn
        for hn in "${handled_cleanup_names[@]+"${handled_cleanup_names[@]}"}"; do
            [[ "$hn" == "$oname" ]] && { already_handled=true; break; }
        done
        $already_handled && continue
        handled_cleanup_names+=("$oname")

        local escaped_oname
        escaped_oname=$(escape-patch-name "$oname")

        # Count how many dropped patches share this name.
        local drop_count=0 j
        for (( j=i; j<${#orig_hashes[@]}; j++ )); do
            local jfound=false jph
            for jph in "${processed_hashes[@]}"; do
                [[ "$jph" == "${orig_hashes[$j]}" ]] && { jfound=true; break; }
            done
            $jfound && continue
            [[ "${orig_names[$j]}" == "$oname" ]] && drop_count=$(( drop_count + 1 ))
        done

        darcs-yes rebase unsuspend --quiet --patches "$escaped_oname"
        local k
        for (( k=0; k<drop_count; k++ )); do
            darcs-yes obliterate --all --quiet --dont-prompt-for-dependencies --patches "$escaped_oname" --last=1
        done
    done

    rm -rf "$rebase_dir"
    printf 'Rebase complete.\n'
}

cmd_rebase_i() (
    local n=$1
    local autosquash=$2

    toplevel > /dev/null 2>&1 || {
        printf '%s: not in a darcs repository\n' "$SCRIPT_NAME" >&2
        exit 1
    }

    local rebase_dir
    read -r rebase_dir < <(rebase-dir)
    local top="${rebase_dir%/_darcs/rebase-i}"
    local todo="$rebase_dir/todo"
    local orig_file="$rebase_dir/original-order"

    if [[ -z $n ]]; then
        [[ -f "$top/_darcs/prefs/defaultrepo" ]] || {
            printf '%s: no default remote configured; specify N or push to a remote first\n' \
                "$SCRIPT_NAME" >&2
            exit 1
        }
        n=0
        while IFS= read -r sline; do
            [[ $sline =~ ^[[:space:]]+\* ]] && n=$(( n + 1 )) || true
        done < <(darcs send --dry-run 2>/dev/null || true)
        [[ $n -gt 0 ]] || {
            printf '%s: no local patches to rebase\n' "$SCRIPT_NAME" >&2
            exit 0
        }
    else
        [[ $n =~ ^[0-9]+$ && $n -gt 0 ]] || {
            printf '%s: N must be a positive integer\n' "$SCRIPT_NAME" >&2
            exit 64
        }
    fi

    [[ ! -f $todo ]] || {
        printf '%s: rebase already in progress; use --continue or --abort\n' "$SCRIPT_NAME" >&2
        exit 1
    }

    local hashes=()
    local names=()
    while IFS=$'\t' read -r phash pname; do
        hashes+=("$phash")
        names+=("$pname")
    done < <(patch-info-oldest-first "$n")

    [[ ${#names[@]} -gt 0 ]] || {
        printf '%s: no patches found\n' "$SCRIPT_NAME" >&2
        exit 1
    }

    # Reorder so fixup!/squash! prefixed patches follow their target
    if $autosquash; then
        local reordered_hashes=()
        local reordered_names=()
        local i j
        for (( i=0; i<${#names[@]}; i++ )); do
            local pname="${names[$i]}"
            [[ $pname == "fixup! "* || $pname == "squash! "* ]] && continue
            reordered_names+=("$pname")
            reordered_hashes+=("${hashes[$i]}")
            for (( j=0; j<${#names[@]}; j++ )); do
                [[ "${names[$j]}" == "fixup! $pname" || "${names[$j]}" == "squash! $pname" ]] || continue
                reordered_names+=("${names[$j]}")
                reordered_hashes+=("${hashes[$j]}")
            done
        done
        names=("${reordered_names[@]}")
        hashes=("${reordered_hashes[@]}")
    fi

    local tmpfile
    tmpfile=$(mktemp)
    trap 'rm -f "$tmpfile"' EXIT

    local i
    for (( i=0; i<${#names[@]}; i++ )); do
        local pname="${names[$i]}"
        local phash="${hashes[$i]}"
        local action=pick
        if $autosquash; then
            [[ $pname == "fixup! "* ]] && action=fixup
            [[ $pname == "squash! "* ]] && action=squash
        fi
        printf '%s %s # %s\n' "$action" "$phash" "$pname" >> "$tmpfile"
    done

    cat >> "$tmpfile" <<'COMMENTS'

# Commands:
#  p, pick   <hash> <name>   = use patch as-is
#  r, reword <hash> <name>   = use patch, but edit its commit message
#  e, edit   <hash> <name>   = use patch, but pause for manual amending
#  s, squash <hash> <name>   = combine with previous patch, editing message
#  f, fixup  <hash> <name>   = like squash, but discard this patch's message
#  d, drop   <hash> <name>   = remove this patch from history
#  x, exec   <command>       = run shell command
#  b, break                  = stop here (resume with --continue)
#
# Lines beginning with '#' are comments and will be ignored.
# Empty lines are also ignored.
# If you remove a line, that patch will be DROPPED.
# Do not modify the hash field — it uniquely identifies each patch.
COMMENTS

    {
        printf '#\n# Patches to be rebased:\n#\n'
        darcs log --summary --last="$n" 2>/dev/null | sed 's/^/# /' || true
    } >> "$tmpfile"

    "${GIT_SEQUENCE_EDITOR:-${EDITOR:-vi}}" "$tmpfile"

    # Build a hash→index map for looking up hashes when parsing editor output.
    # (The user edits action and name but the hash must stay intact.)
    local todo_lines=()
    while IFS= read -r line; do
        [[ $line =~ ^[[:space:]]*# ]] && continue
        [[ $line =~ ^[[:space:]]*$ ]] && continue

        local action rest
        action=${line%% *}
        rest=${line#* }

        case $action in
            p)       action=pick   ;;
            r)       action=reword ;;
            e)       action=edit   ;;
            s)       action=squash ;;
            f)       action=fixup  ;;
            d)       action=drop   ;;
            x)       action='exec'  ;;
            b)       action='break' ;;
            pick|reword|edit|squash|fixup|drop|exec|break) ;;
            *)
                printf '%s: unknown action %q in: %s\n' "$SCRIPT_NAME" "$action" "$line" >&2
                exit 1
                ;;
        esac
        todo_lines+=("$action $rest")
    done < "$tmpfile"

    if [[ ${#todo_lines[@]} -eq 0 ]]; then
        local i
        for (( i=0; i<${#names[@]}; i++ )); do
            todo_lines+=("drop ${hashes[$i]} ${names[$i]}")
        done
    fi

    local first_action=${todo_lines[0]%% *}
    [[ $first_action != squash && $first_action != fixup ]] || {
        printf '%s: first action cannot be squash or fixup\n' "$SCRIPT_NAME" >&2
        exit 1
    }

    # If the todo is identical to the original (all picks, same order), nothing to do.
    local unchanged=true
    if [[ ${#todo_lines[@]} -eq ${#names[@]} ]]; then
        local i
        for (( i=0; i<${#todo_lines[@]}; i++ )); do
            if [[ "${todo_lines[$i]}" != "pick ${hashes[$i]} # ${names[$i]}" ]]; then
                unchanged=false
                break
            fi
        done
    else
        unchanged=false
    fi
    if $unchanged; then
        printf '%s: nothing to do\n' "$SCRIPT_NAME"
        exit 0
    fi

    # Suspend newest-first to avoid dependency cascades
    local i
    for (( i=${#hashes[@]}-1; i>=0; i-- )); do
        darcs-yes rebase suspend --all --quiet --hash "${hashes[$i]}"
    done

    local suspended_count=0
    suspended_count=$(darcs rebase log 2>/dev/null | grep -c '^\s*\*' || true)
    if [[ $suspended_count -gt $n ]]; then
        printf '%s: warning: darcs suspended %d extra patch(es) due to dependencies\n' \
            "$SCRIPT_NAME" $(( suspended_count - n )) >&2
        printf '%s: run "darcs rebase log" to see all suspended patches\n' "$SCRIPT_NAME" >&2
    fi

    mkdir -p "$rebase_dir"
    # Store "hash\tname" in original-order for use by --abort and cleanup.
    local i
    for (( i=0; i<${#hashes[@]}; i++ )); do
        printf '%s\t%s\n' "${hashes[$i]}" "${names[$i]}"
    done > "$orig_file"
    printf '%s\n' "${todo_lines[@]}" > "$todo"

    execute-todo "$rebase_dir"
)

cmd_continue() (
    local rebase_dir
    read -r rebase_dir < <(rebase-dir)
    local todo="$rebase_dir/todo"

    [[ -f $todo ]] || {
        printf '%s: no rebase in progress\n' "$SCRIPT_NAME" >&2
        exit 1
    }

    execute-todo "$rebase_dir"
)

cmd_skip() (
    local rebase_dir
    read -r rebase_dir < <(rebase-dir)
    local todo="$rebase_dir/todo"

    [[ -f $todo ]] || {
        printf '%s: no rebase in progress\n' "$SCRIPT_NAME" >&2
        exit 1
    }

    local lines=()
    while IFS= read -r line; do
        lines+=("$line")
    done < "$todo"

    # Name is third field (after action and hash) for patch actions.
    local first="${lines[0]}"
    local first_action="${first%% *}"
    local first_rest="${first#* }"
    case $first_action in
        exec|break)
            printf 'Skipping: %s\n' "$first_rest"
            ;;
        *)
            local skip_name="${first_rest#* }"
            printf 'Skipping: %s\n' "${skip_name#\# }"
            ;;
    esac

    if [[ ${#lines[@]} -le 1 ]]; then
        rm -rf "$rebase_dir"
        printf 'Rebase complete.\n'
        return
    fi

    printf '%s\n' "${lines[@]:1}" > "$todo"
    execute-todo "$rebase_dir"
)

cmd_abort() (
    local rebase_dir
    read -r rebase_dir < <(rebase-dir)
    local todo="$rebase_dir/todo"
    local orig_file="$rebase_dir/original-order"

    [[ -f $todo ]] || {
        printf '%s: no rebase in progress\n' "$SCRIPT_NAME" >&2
        exit 1
    }

    [[ -f $orig_file ]] || {
        printf '%s: original-order file missing; cannot abort cleanly\n' "$SCRIPT_NAME" >&2
        exit 1
    }

    local orig_hashes=()
    local orig_names=()
    while IFS=$'\t' read -r ohash oname; do
        orig_hashes+=("$ohash")
        orig_names+=("$oname")
    done < "$orig_file"

    local suspended_names=()
    while IFS= read -r sline; do
        [[ $sline =~ ^[[:space:]]+\*[[:space:]] ]] || continue
        suspended_names+=("${sline#*\* }")
    done < <(darcs rebase log 2>/dev/null || true)

    # Identify patches already back in repo (not currently suspended) to re-suspend before restore.
    # We check by name; for duplicate names this may be imprecise but abort is best-effort.
    local needs_resuspend_hashes=()
    local i
    for (( i=0; i<${#orig_names[@]}; i++ )); do
        local oname="${orig_names[$i]}"
        local found=false sname
        for sname in "${suspended_names[@]}"; do
            [[ $sname == "$oname" ]] && { found=true; break; }
        done
        $found || needs_resuspend_hashes+=("${orig_hashes[$i]}")
    done

    if [[ ${#needs_resuspend_hashes[@]} -gt 0 ]]; then
        printf '%s: warning: some patches were already applied; abort may be incomplete\n' \
            "$SCRIPT_NAME" >&2
        printf '%s: if squash/fixup was executed, merged patches cannot be split\n' \
            "$SCRIPT_NAME" >&2
    fi

    local i
    for (( i=${#needs_resuspend_hashes[@]}-1; i>=0; i-- )); do
        darcs-yes rebase suspend --all --quiet --hash "${needs_resuspend_hashes[$i]}"
    done

    local i
    for (( i=0; i<${#orig_names[@]}; i++ )); do
        local escaped_oname
        escaped_oname=$(escape-patch-name "${orig_names[$i]}")
        darcs-yes rebase unsuspend --quiet --patches "$escaped_oname" --last=1 >/dev/null 2>&1 || {
            printf '%s: warning: could not unsuspend %q\n' "$SCRIPT_NAME" "${orig_names[$i]}" >&2
        }
    done

    rm -rf "$rebase_dir"
    printf 'Rebase aborted. Repository restored to original state.\n'
)

cmd_status() (
    local rebase_dir
    read -r rebase_dir < <(rebase-dir)
    local todo="$rebase_dir/todo"

    if [[ ! -f $todo ]]; then
        printf 'No rebase in progress.\n'
        exit 0
    fi

    printf 'Remaining actions:\n'
    cat "$todo"
    printf '\nCurrently suspended patches:\n'
    darcs rebase log 2>/dev/null || printf '  (none)\n'
)

help() {
    cat - <<EOF
$SCRIPT_NAME - git rebase --interactive mimic for darcs

Usage:
  $SCRIPT_NAME [--autosquash] [N]  interactively rebase; N defaults to local (unpushed) patches
  $SCRIPT_NAME --continue          resume after an 'edit', 'exec', or 'break' pause
  $SCRIPT_NAME --abort           cancel rebase and restore original state
  $SCRIPT_NAME --skip            skip current failing patch and continue
  $SCRIPT_NAME --status          show current rebase progress
  $SCRIPT_NAME --help            show this help

Options:
  --autosquash  move fixup!/squash! prefixed patches after their target automatically

Actions (in the editor):
  p, pick   <hash> <name>   use patch as-is
  r, reword <hash> <name>   use patch, but edit its commit message
  e, edit   <hash> <name>   use patch, but pause for manual amending
  s, squash <hash> <name>   combine with previous patch, editing message
  f, fixup  <hash> <name>   like squash, but discard this patch's message
  d, drop   <hash> <name>   remove this patch from history
  x, exec   <command>       run shell command
  b, break                  stop here (resume with --continue)

EOF
}

main() (
    local autosquash=false
    local parsed
    read -r parsed < <(
        getopt --options=h \
               --longoptions=help,continue,abort,skip,status,autosquash \
               --name "$SCRIPT_NAME" \
               -- "$@"
    )
    eval set -- "$parsed"

    while true; do
        case "$1" in
            -h|--help)
                help
                exit 0
                ;;
            --continue)
                shift
                cmd_continue
                exit 0
                ;;
            --abort)
                shift
                cmd_abort
                exit 0
                ;;
            --skip)
                shift
                cmd_skip
                exit 0
                ;;
            --status)
                shift
                cmd_status
                exit 0
                ;;
            --autosquash)
                autosquash=true
                shift
                ;;
            --)
                shift
                break
                ;;
        esac
    done

    if [[ $# -gt 1 ]]; then
        printf '%s: too many arguments\n' "$SCRIPT_NAME" >&2
        exit 64
    fi

    cmd_rebase_i "${1:-}" "$autosquash"
)

main "$@"
